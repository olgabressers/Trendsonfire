							'liferay-calendar-util',
							'resize-plugin',
						],
					},
					'liferay-scheduler-models': {
						path: 'scheduler_models.js',
						requires: [
							'aui-datatype',
							'dd-plugin',
							'liferay-calendar-util',
						],
					},
				},
				root: MODULE_PATH + '/js/legacy/',
			},
		},
	});
})();
} catch(error) {console.error(error);}</script>
